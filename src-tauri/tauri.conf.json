{
  "productName": "VoxForge",
  "version": "0.3.0",
  "identifier": "app.voxforge",
  "build": {
    "beforeDevCommand": "vite",
    "devUrl": "http://localhost:5173",
    "frontendDist": "../dist"
  },
  "app": {
    "windows": [
      {
        "label": "main",
        "title": "VoxForge",
        "width": 780,
        "height": 620,
        "minWidth": 640,
        "minHeight": 500,
        "resizable": true,
        "fullscreen": false,
        "visible": true,
        "center": true,
        "decorations": false,
        "transparent": true
      }
    ],
    "security": {
      "csp": null
    }
  },
  "bundle": {
    "active": true,
    "category": "Utility",
    "targets": [
      "deb",
      "appimage"
    ],
    "icon": [
      "icons/32x32.png",
      "icons/128x128.png",
      "icons/128x128@2x.png",
      "icons/icon.png"
    ],
    "resources": [
      "icons/tray-icon.png"
    ],
    "linux": {
      "deb": {
        "depends": [
          "xdotool",
          "libssl3"
        ],
        "section": "utils",
        "priority": "optional",
        "postInstallScript": "scripts/postinst.sh",
        "postRemoveScript": "scripts/postrm.sh"
      },
      "appimage": {
        "bundleMediaFramework": false
      }
    }
  }
}

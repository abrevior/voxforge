{
  "productName": "VoxForge",
  "version": "0.1.0",
  "identifier": "app.voxforge",
  "build": {
    "beforeDevCommand": "npm run dev",
    "devUrl": "http://localhost:5173",
    "frontendDist": "../dist"
  },
  "app": {
    "windows": [
      {
        "title": "VoxForge",
        "width": 900,
        "height": 700,
        "minWidth": 400,
        "minHeight": 300,
        "resizable": true,
        "fullscreen": false,
        "visible": false
      }
    ],
    "security": {
      "csp": null
    }
  },
  "bundle": {
    "active": true,
    "targets": [
      "deb"
    ],
    "linux": {
      "deb": {
        "depends": [
          "xdotool",
          "libssl3"
        ]
      },
      "appimage": {
        "bundleMediaFramework": false
      }
    }
  }
}

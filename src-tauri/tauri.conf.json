{
  "productName": "VoxForge",
  "version": "0.1.0",
  "identifier": "app.voxforge",
  "build": {
    "beforeDevCommand": "vite",
    "devUrl": "http://localhost:5173",
    "frontendDist": "../dist"
  },
  "app": {
    "windows": [
      {
        "label": "main",
        "title": "VoxForge",
        "width": 900,
        "height": 700,
        "minWidth": 400,
        "minHeight": 300,
        "resizable": true,
        "fullscreen": false,
        "visible": true,
        "center": true
      }
    ],
    "security": {
      "csp": null
    }
  },
  "bundle": {
    "active": true,
    "targets": [
      "deb",
      "appimage"
    ],
    "icon": [
      "icons/32x32.png",
      "icons/128x128.png",
      "icons/128x128@2x.png",
      "icons/icon.png"
    ],
    "resources": [
      "icons/tray-icon.png"
    ],
    "linux": {
      "deb": {
        "depends": [
          "xdotool",
          "libssl3"
        ]
      },
      "appimage": {
        "bundleMediaFramework": false
      }
    }
  }
}
